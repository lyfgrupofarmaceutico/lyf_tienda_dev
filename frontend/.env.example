# ===========================================
# L&F Grupo Farmacéutico - Frontend .env.example
# ===========================================
# Copia este archivo como .env y configura tus variables

# -------------------------------------------
# API Backend URL
# -------------------------------------------
# Desarrollo local
VITE_API_URL=http://localhost:8000/api/v1

# Producción (cambiar por tu dominio)
# VITE_API_URL=https://api.tudominio.com/api/v1

# -------------------------------------------
# WhatsApp para pedidos
# -------------------------------------------
# Número de WhatsApp para recibir pedidos (código país + número, sin espacios ni +)
# Ejemplo: 57 para Colombia, seguido del número de 10 dígitos
VITE_WHATSAPP_NUMBER=573182825718

# Número alternativo (opcional)
# VITE_WHATSAPP_NUMBER_ALT=573046360854
